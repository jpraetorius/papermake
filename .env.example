# ── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000
RUST_LOG=papermake_server=info,papermake_registry=info
# Maximum number of CPU-bound Typst renders allowed at once per server.
MAX_CONCURRENT_RENDERS=10
# Wall-clock render timeout in seconds, including queue wait for a render slot.
RENDER_TIMEOUT_SECONDS=300
# Items per batch shard (the unit of work a worker claims). Smaller = finer
# parallelism/reclaim across workers but more shard descriptors.
SHARD_SIZE=500
# Extra font directories to scan at startup (`:`-separated; missing dirs
# skipped). Merged with Typst's embedded fonts and any template-bundled fonts.
# In Docker the image sets this to /fonts, mounted from the repo's ./fonts.
FONTS_DIR=/fonts

# ── S3 / object storage (server and worker) ─────────────────────────────────
# Point these at RustFS for local dev, or any S3-compatible endpoint.
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=papermake-templates
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ── Buffered analytics + retention (server) ─────────────────────────────────
# Stable id for this render instance (used in flushed S3 keys). Optional;
# a random uuid is generated when unset.
PAPERMAKE_INSTANCE_ID=server-1
# Flush the in-memory analytics buffer to S3 on this interval...
FLUSH_INTERVAL_SECONDS=30
# ...or eagerly once it reaches this many records.
FLUSH_MAX_RECORDS=1000
# Default output retention in days (0 = keep forever). Overridable per-template
# (TemplateMetadata.retain_days) and per-render (render request retain_days).
RENDER_RETENTION_DAYS=30

# ── Worker (one binary, two roles) ──────────────────────────────────────────
# WORKER_ROLE: "render" (poll + render shards; scale these), "maintenance"
# (aggregate summary.json + prune; run one), or "all" (both; default, dev/single).
WORKER_ROLE=all
# How often this worker acts. Defaults by role (set to override): render 5s
# (fast job pickup), maintenance 30s, all 10s.
WORKER_INTERVAL_SECONDS=10
# [maintenance] How long to keep raw analytics NDJSON (summary.json survives).
ANALYTICS_RETENTION_DAYS=30
# [maintenance] How long to keep batch-job docs (jobs/{id}/…) after creation, in
# days (0 = keep forever). They accrue one per batch submission, so prune them.
JOB_RETENTION_DAYS=7
# [render] Shard lease (seconds): a dead worker's shard is reclaimable this long
# after its last heartbeat.
WORKER_LEASE_SECONDS=120
# [render] Give up on a shard (mark it failed) after this many claims.
WORKER_MAX_ATTEMPTS=3
# Unique per process (shard-claim owner + analytics instance key). Optional;
# defaults to the container hostname, then PID — so scaled replicas differ.
PAPERMAKE_WORKER_ID=worker-1
# Retention for batch-rendered outputs (days; 0 = keep forever).
RENDER_RETENTION_DAYS=30
