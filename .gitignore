# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

.idea/

.env*
!.env.example

# Local font drop-in mounted into the containers at /fonts (see docker-compose).
# Root-anchored so template-bundled fonts (templates/*/assets/fonts/) still track.
/fonts/
/storage/
.vscode/
data/

# Local sample templates (kept on disk, not tracked)
/templates/alh-corporate/
/templates/monaspace-demo/

# Local-only font helper (verification convenience, not part of the repo)
/scripts/fetch-fonts.sh
